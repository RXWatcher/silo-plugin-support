{
  "plugin_id": "silo.support",
  "version": "0.4.3",
  "checksum": "__CHECKSUM__",
  "silo_api_version": "v1",
  "category": "Operations",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "http_routes.v1",
      "id": "support",
      "display_name": "Support",
      "description": "Customer support shell — modules ship in follow-up releases."
    }
  ],
  "http_routes": [
    {
      "id": "customer_home",
      "method": "GET",
      "path": "/",
      "access": "authenticated",
      "navigable": true,
      "navigation_label": "Support",
      "navigation_kind": "user"
    },
    {
      "id": "customer_bootstrap",
      "method": "GET",
      "path": "/api/customer/bootstrap",
      "access": "authenticated"
    },
    {
      "id": "admin_page",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "Support",
      "navigation_kind": "admin"
    },
    {
      "id": "admin_get_config",
      "method": "GET",
